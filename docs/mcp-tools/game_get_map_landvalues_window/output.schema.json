{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "civone/mcp-tools/game_get_map_landvalues_window/output",
  "title": "game_get_map_landvalues_window – output",
  "type": "object",
  "required": ["ok", "truncated", "maxChars", "returnedChars"],
  "properties": {
    "ok":            { "type": "boolean" },
    "truncated":     { "type": "boolean" },
    "maxChars":      { "type": "integer" },
    "returnedChars": { "type": "integer" },
    "data": {
      "type": "object",
      "required": ["mapSize", "bounds", "landValuesFormat", "rows"],
      "properties": {
        "mapSize": {
          "type": "object",
          "required": ["width", "height"],
          "properties": {
            "width":  { "type": "integer" },
            "height": { "type": "integer" }
          }
        },
        "bounds": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x":      { "type": "integer" },
            "y":      { "type": "integer" },
            "width":  { "type": "integer" },
            "height": { "type": "integer" }
          }
        },
        "landValuesFormat": {
          "type": "string",
          "const": "hex-csv-per-row",
          "description": "Each row is a comma-separated list of uppercase 2-digit hex values, e.g. '01,0A,FF'."
        },
        "rows": {
          "type": "array",
          "description": "One string per row. Each string contains 'width' hex values separated by commas.",
          "items": {
            "type": "string",
            "pattern": "^[0-9A-F]{2}(,[0-9A-F]{2})*$"
          }
        }
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": ["INVALID_BOUNDS", "NO_GAME", "PAYLOAD_TRUNCATED"]
        },
        "message": { "type": "string" }
      }
    }
  }
}
