{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "civone/mcp-tools/game_get_visibility/output",
  "title": "game_get_visibility – output",
  "type": "object",
  "required": ["ok", "truncated", "maxChars", "returnedChars"],
  "properties": {
    "ok":            { "type": "boolean" },
    "truncated":     { "type": "boolean" },
    "maxChars":      { "type": "integer" },
    "returnedChars": { "type": "integer" },
    "data": {
      "type": "object",
      "required": ["playerId", "bounds", "exploredRows", "visibleRows"],
      "properties": {
        "playerId": {
          "type": "integer",
          "description": "The player whose visibility is returned."
        },
        "bounds": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x":      { "type": "integer" },
            "y":      { "type": "integer" },
            "width":  { "type": "integer" },
            "height": { "type": "integer" }
          }
        },
        "exploredRows": {
          "type": "array",
          "description": "One binary string per row. Each character is '1' (explored) or '0' (unexplored).",
          "items": {
            "type": "string",
            "pattern": "^[01]+$"
          }
        },
        "visibleRows": {
          "type": "array",
          "description": "One binary string per row. Each character is '1' (currently visible) or '0' (not visible).",
          "items": {
            "type": "string",
            "pattern": "^[01]+$"
          }
        }
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": ["INVALID_BOUNDS", "INVALID_PLAYER", "NO_GAME", "PAYLOAD_TRUNCATED"]
        },
        "message": { "type": "string" }
      }
    }
  }
}
