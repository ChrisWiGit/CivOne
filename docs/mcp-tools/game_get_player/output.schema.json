{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "civone/mcp-tools/game_get_player/output",
  "title": "game_get_player – output",
  "type": "object",
  "required": ["ok", "truncated", "maxChars", "returnedChars"],
  "properties": {
    "ok": { "type": "boolean" },
    "truncated": { "type": "boolean" },
    "maxChars": { "type": "integer" },
    "returnedChars": { "type": "integer" },
    "data": {
      "type": "object",
      "description": "Single player object (or projected subset when keys filter is used).",
      "properties": {
        "Id": { "type": "integer" },
        "PlayerGuid": { "type": "string", "format": "uuid" },
        "TribeName": { "type": ["string", "null"] },
        "Gold": { "type": "integer" },
        "Science": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": ["NO_GAME", "INVALID_PARAMS", "MISSING_SELECTOR", "AMBIGUOUS_SELECTOR", "INVALID_PLAYER_ID", "PLAYER_NOT_FOUND", "INVALID_KEYS", "PAYLOAD_TRUNCATED"]
        },
        "message": { "type": "string" },
        "failedSegment": { "type": ["string", "null"] }
      }
    }
  }
}
