{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "civone/mcp-tools/game_get_settings/input",
  "title": "game_get_settings – input",
  "description": "Returns persistent and runtime settings. Omit 'keys' to get the full grouped payload.",
  "type": "object",
  "properties": {
    "keys": {
      "type": "array",
      "description": "Optional list of dotted keys to return. If omitted, all settings are returned grouped by category.",
      "items": {
        "type": "string",
        "enum": [
          "paths.storageDirectory",
          "paths.captureDirectory",
          "paths.dataDirectory",
          "paths.pluginsDirectory",
          "paths.savesDirectory",
          "paths.cosSavesDirectory",
          "paths.soundsDirectory",
          "display.windowTitle",
          "display.graphicsMode",
          "display.fullScreen",
          "display.scale",
          "display.aspectRatio",
          "display.expandWidth",
          "display.expandHeight",
          "display.windowWidth",
          "display.windowHeight",
          "display.windowPosX",
          "display.windowPosY",
          "display.cursorType",
          "display.destroyAnimation",
          "patches.rightSideBar",
          "patches.revealWorld",
          "patches.debugMenu",
          "patches.deityEnabled",
          "patches.arrowHelper",
          "patches.customMapSize",
          "patches.pathFinding",
          "patches.autoSettlers",
          "patches.riverFastMovement",
          "patches.canalCity",
          "patches.preferSveSaveFormat",
          "patches.useUncheckedCastSanitizer",
          "patches.globalWarmingFeatureFlags",
          "gameOptions.instantAdvice",
          "gameOptions.autoSave",
          "gameOptions.endOfTurn",
          "gameOptions.animations",
          "gameOptions.sound",
          "gameOptions.enemyMoves",
          "gameOptions.civilopediaText",
          "gameOptions.palace",
          "gameOptions.taxRate",
          "runtime.demo",
          "runtime.setup",
          "runtime.dataCheck",
          "runtime.mcpEnabled",
          "runtime.mcpNoAuth",
          "runtime.free",
          "runtime.showCredits",
          "runtime.showIntro",
          "runtime.loadSaveGameSlot",
          "runtime.loadCosFile",
          "runtime.initialSeed",
          "runtime.profileName",
          "runtime.noSound",
          "runtime.softwareRender",
          "runtime.mcpArtifacts",
          "runtime.mcpMaxJsonChars"
        ]
      },
      "uniqueItems": true
    },
    "sessionId": {
      "type": "string",
      "description": "Optional caller-supplied identifier."
    },
    "includeCursor": {
      "type": "boolean",
      "description": "Reserved for future use.",
      "default": false
    }
  },
  "additionalProperties": false
}
