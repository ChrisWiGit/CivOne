{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "civone/mcp-tools/game_get_settings/output",
  "title": "game_get_settings – output",
  "description": "Settings payload wrapped in the standard JSON tool envelope.",
  "type": "object",
  "required": ["ok", "truncated", "maxChars", "returnedChars"],
  "properties": {
    "ok": { "type": "boolean" },
    "truncated": { "type": "boolean" },
    "maxChars": { "type": "integer" },
    "returnedChars": { "type": "integer" },
    "data": {
      "description": "Present when ok=true. Either a grouped object (all settings) or a flat key→value map (filtered).",
      "oneOf": [
        {
          "title": "Grouped (no keys filter)",
          "type": "object",
          "properties": {
            "paths":       { "type": "object" },
            "display":     { "type": "object" },
            "patches":     { "type": "object" },
            "gameOptions": { "type": "object" },
            "runtime":     { "type": "object" }
          }
        },
        {
          "title": "Filtered (keys provided)",
          "type": "object",
          "description": "Keys are the requested dotted setting names. Values are scalar or enum objects.",
          "additionalProperties": {
            "oneOf": [
              { "type": ["string", "number", "boolean"] },
              {
                "type": "object",
                "required": ["value"],
                "properties": {
                  "value":  { "type": ["integer", "boolean"] },
                  "name":   { "type": "string", "description": "Enum member name." },
                  "names":  { "type": "array", "items": { "type": "string" }, "description": "Flag names (flags enum)." },
                  "text":   { "type": "string", "description": "Human-readable label." }
                }
              }
            ]
          }
        }
      ]
    },
    "error": {
      "type": "object",
      "description": "Present when ok=false.",
      "required": ["code", "message"],
      "properties": {
        "code":    { "type": "string", "enum": ["INVALID_KEYS", "PAYLOAD_TRUNCATED"] },
        "message": { "type": "string" }
      }
    }
  }
}
