{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "civone/mcp-tools/game_get_players/output",
  "title": "game_get_players – output",
  "type": "object",
  "required": ["ok", "truncated", "maxChars", "returnedChars"],
  "properties": {
    "ok":            { "type": "boolean" },
    "truncated":     { "type": "boolean" },
    "maxChars":      { "type": "integer" },
    "returnedChars": { "type": "integer" },
    "data": {
      "description": "Array of player objects (one element when playerId was specified).",
      "type": "array",
      "items": {
        "type": "object",
        "description": "Player object. Present keys depend on the 'keys' filter.",
        "properties": {
          "id":              { "type": "integer", "description": "0-based player index." },
          "playerGuid":      { "type": "string", "format": "uuid", "description": "Stable player GUID. Prefer over 'id' for cross-turn references." },
          "tribeName":       { "type": "string" },
          "gold":            { "type": "integer" },
          "science":         { "type": "integer" },
          "currentResearch": { "type": ["string", "null"] },
          "advances": {
            "type": "array",
            "items": { "type": "string" }
          },
          "diplomacy": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "targetPlayerGuid": { "type": "string", "format": "uuid" },
                "status":           { "type": "string" }
              }
            }
          }
        },
        "additionalProperties": true
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code":    { "type": "string", "enum": ["NO_GAME", "INVALID_PLAYER", "PAYLOAD_TRUNCATED"] },
        "message": { "type": "string" }
      }
    }
  }
}
