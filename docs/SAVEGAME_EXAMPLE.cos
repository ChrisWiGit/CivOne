  # Allowed values: Animations, Sound, CivilopediaText, EndOfTurn, InstantAdvice, AutoSave, EnemyMoves, Palace
  GameOptions:
  - Animations
  - CivilopediaText
  - Palace
  # Maps each advance ID to the player number who first discovered it.
  AdvanceOrigin:
    16: 0
    42: 0
    0: 0
    1: 0
    17: 1
    18: 1
    22: 1
    9: 1
    25: 1
    33: 1
    30: 1
    2: 1
    45: 1
    19: 1
  # Replay events recorded during the game session.
  ReplayData: []
  # Global peace turn counter from the original save format. Reserved for future diplomacy logic.
  # Allowed values: [0 to 65535]
  PeaceTurns: 23
  # Legacy future-tech counter from the original save format. New YAML should prefer Players[].FutureTechCount. For backward compatibility this still mirrors the human player's count.
  # Allowed values: [0 to 65535]
  PlayerFutureTech: 0
  # Global warming simulation state (count, pollution level, warning indicator).
  GlobalWarming:
    # The number of times global warming has triggered since the start of the game. Each event raises the pollution threshold for the next event by 2.
    GlobalWarmingCount: 0
    # The number of polluted map squares at the end of the last turn.
    PollutedSquaresCount: 0
    # The warming indicator color shown in the status bar.
    # Allowed values: None, DarkRed, LightRed, Yellow, White
    WarmingIndicator: None
