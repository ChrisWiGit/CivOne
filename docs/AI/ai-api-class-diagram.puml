@startuml
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "API (api/src/Agents)" {
  interface IAgentInformation {
    +GetName() : string
    +GetAuthor() : string
    +GetVersion() : (int Major, int Minor, int Patch)
    +GetDescription() : string
    +GetUuid() : Guid
  }

  interface IAgentMemory {
    +SetMemory(yaml: string) : void
    +GetMemory() : string
  }

  interface IAgentRegistration {
    +GetInformation() : IAgentInformation
    +GetMemory() : IAgentMemory
    +GetTurnBasedController() : ITurnBasedController
  }

  interface ITurnBasedController {
    +OnTurn(session: ITurnSession) : void
  }

  interface ITurnSession {
    +Context : ITurnContext
    +Events : IEventJournal
    +Commands : ITurnCommandGateway
    +EndTurn() : void
  }

  interface ITurnContext {
    +GameTurn : int
    +CurrentCivilization : ICivilizationView
    +Map : IMapView
    +OwnUnits : IReadOnlyList<IUnitView>
    +OwnCities : IReadOnlyList<ICityView>
    +AvailableResearchNames : IReadOnlyList<string>
    +CurrentResearchName : string?
  }

  interface ITurnCommandGateway {
    +Units : IUnitCommandGateway
    +Cities : ICityCommandGateway
    +Research : IResearchCommandGateway
  }

  interface IUnitCommandGateway {
    +Move(unitId: Guid, dx: int, dy: int) : ICommandResult
    +Fortify(unitId: Guid) : ICommandResult
    +Wake(unitId: Guid) : ICommandResult
    +SetGoto(unitId: Guid, x: int, y: int) : ICommandResult
    +ClearGoto(unitId: Guid) : ICommandResult
    +Disband(unitId: Guid) : ICommandResult
    +FoundCity(unitId: Guid) : ICommandResult
    +BuildRoad(unitId: Guid) : ICommandResult
    +BuildIrrigation(unitId: Guid) : ICommandResult
    +BuildMine(unitId: Guid) : ICommandResult
  }

  interface ICityCommandGateway {
    +ChooseProduction(cityId: Guid, productionName: string) : ICommandResult
  }

  interface IResearchCommandGateway {
    +ChooseResearch(researchName: string) : ICommandResult
  }

  interface ICommandResult {
    +Success : bool
    +ErrorCode : string
    +ErrorMessage : string?
    +SequenceBefore : ulong
    +SequenceAfter : ulong
  }

  class CommandResult {
    +Success : bool
    +ErrorCode : string
    +ErrorMessage : string?
    +SequenceBefore : ulong
    +SequenceAfter : ulong
  }

  interface IEventJournal {
    +ReadSince(sequence: ulong) : EventReadResult
    +CurrentSequence : ulong
  }

  class AgentEvent {
    +Sequence : ulong
    +Kind : AgentEventKind
    +EntityId : Guid?
    +Name : string?
    +Message : string?
  }

  class EventReadResult {
    +CursorExpired : bool
    +RequiresFullResync : bool
    +FromSequence : ulong
    +ToSequence : ulong
    +Events : IReadOnlyList<AgentEvent>
  }

  enum AgentEventKind {
    Unknown
    TurnStarted
    UnitMoved
    TilesExplored
    CityProductionCompleted
    CityProductionChanged
    ResearchCompleted
    ResearchChanged
    UnitDestroyed
    CityLost
    UnitDisbanded
  }

  interface ICivilizationView
  interface IUnitView
  interface ICityView
  interface ITileView
  interface IMapView
}

package "Runtime (src/Agents)" {
  class TurnBasedAgentHost {
    +Instance : TurnBasedAgentHost
    +ShouldHandlePlayer(player: Player?) : bool
    +RunForCurrentPlayerIfNeeded() : bool
  }

  interface IAgentBindingResolver {
    +Resolve(player: Player) : IAgentRegistration
  }

  class AgentBindingResolver {
    +Resolve(player: Player) : IAgentRegistration
  }

  class AgentRegistry {
    +Instance : AgentRegistry
    +Register(registration: IAgentRegistration) : void
    +BindPlayer(playerGuid: Guid, agentGuid: Guid) : void
    +TryResolve(playerGuid: Guid, out registration: IAgentRegistration?) : bool
  }

  class AgentLoaderEntry {
    +Register(registration: IAgentRegistration) : void
    +BindPlayer(playerGuid: Guid, agentGuid: Guid) : void
  }

  class LegacyAgentRegistration {
    +GetInformation() : IAgentInformation
    +GetMemory() : IAgentMemory
    +GetTurnBasedController() : ITurnBasedController
  }

  class LegacyAgentInformation {
    +GetName() : string
    +GetAuthor() : string
    +GetVersion() : (int Major, int Minor, int Patch)
    +GetDescription() : string
    +GetUuid() : Guid
  }

  class LegacyAgentMemory {
    +SetMemory(yaml: string) : void
    +GetMemory() : string
  }

  class DefaultTurnBasedController {
    +OnTurn(session: ITurnSession) : void
  }

  class TurnSession {
    +Context : ITurnContext
    +Events : IEventJournal
    +Commands : ITurnCommandGateway
    +EndTurn() : void
  }

  class TurnContext

  class TurnCommandGateway {
    +Units : IUnitCommandGateway
    +Cities : ICityCommandGateway
    +Research : IResearchCommandGateway
  }

  class UnitCommandGateway
  class CityCommandGateway
  class ResearchCommandGateway

  interface IAgentMemoryStore {
    +TryLoad(playerGuid: Guid, out yaml: string?) : bool
    +Save(playerGuid: Guid, information: IAgentInformation, gameTurn: int, yaml: string) : void
  }

  class FileAgentMemoryStore {
    +TryLoad(playerGuid: Guid, out yaml: string?) : bool
    +Save(playerGuid: Guid, information: IAgentInformation, gameTurn: int, yaml: string) : void
  }

  class RingEventJournal
}

' API relations
IAgentRegistration --> IAgentInformation : GetInformation()
IAgentRegistration --> IAgentMemory : GetMemory()
IAgentRegistration --> ITurnBasedController : GetTurnBasedController()

ITurnSession --> ITurnContext : Context
ITurnSession --> IEventJournal : Events
ITurnSession --> ITurnCommandGateway : Commands

ITurnCommandGateway --> IUnitCommandGateway : Units
ITurnCommandGateway --> ICityCommandGateway : Cities
ITurnCommandGateway --> IResearchCommandGateway : Research

IUnitCommandGateway --> ICommandResult
ICityCommandGateway --> ICommandResult
IResearchCommandGateway --> ICommandResult
ICommandResult <|.. CommandResult

IEventJournal --> EventReadResult
EventReadResult --> AgentEvent
AgentEvent --> AgentEventKind

ITurnContext --> ICivilizationView
ITurnContext --> IMapView
ITurnContext --> IUnitView
ITurnContext --> ICityView
IMapView --> ITileView

' Runtime to API mappings
TurnBasedAgentHost --> IAgentBindingResolver
TurnBasedAgentHost --> IAgentMemoryStore
TurnBasedAgentHost --> IAgentRegistration
TurnBasedAgentHost --> RingEventJournal

AgentBindingResolver ..|> IAgentBindingResolver
LegacyAgentRegistration ..|> IAgentRegistration
LegacyAgentInformation ..|> IAgentInformation
LegacyAgentMemory ..|> IAgentMemory
DefaultTurnBasedController ..|> ITurnBasedController

TurnSession ..|> ITurnSession
TurnContext ..|> ITurnContext
TurnCommandGateway ..|> ITurnCommandGateway
UnitCommandGateway ..|> IUnitCommandGateway
CityCommandGateway ..|> ICityCommandGateway
ResearchCommandGateway ..|> IResearchCommandGateway

FileAgentMemoryStore ..|> IAgentMemoryStore
RingEventJournal ..|> IEventJournal

AgentLoaderEntry --> AgentRegistry
AgentRegistry --> IAgentRegistration

@enduml
