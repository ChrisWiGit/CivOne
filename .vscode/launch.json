{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Test Coverage Task",
			"type": "node-terminal",
			"request": "launch",
			"command": "echo Test coverage task finished.",
			"preLaunchTask": "test-coverage"
		},
		{
			"name": "Launch Game",
			"type": "coreclr",
			"request": "launch",
			"preLaunchTask": "build",
			"program": "${workspaceRoot}/runtime/sdl/bin/Debug/net9.0/CivOne.SDL.dll",
			"args": [],
			"cwd": "${workspaceRoot}",
			"stopAtEntry": false,
			"console": "internalConsole",
			"internalConsoleOptions": "openOnSessionStart",
			"justMyCode": false
		},
		{
			"name": "Quick Launch Game (seed +32768)",
			"type": "coreclr",
			"request": "launch",
			"preLaunchTask": "build",
			"program": "${workspaceRoot}/runtime/sdl/bin/Debug/net9.0/CivOne.SDL.dll",
			"args": [
				"--seed",
				"32768",
				"--skip-credits",
				"--skip-intro",
				"--no-sound",
				"--no-data-check"
			],
